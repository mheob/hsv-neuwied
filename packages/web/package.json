{
  "name": "@hsv-neuwied/web",
  "version": "0.0.0-development",
  "private": true,
  "description": "Der HSV Neuwied wurde von alten Freunden gegründet und bietet in und für Neuwied eine gute Gemeinschaft.",
  "license": "MIT",
  "scripts": {
    "build": "next build",
    "dev": "next",
    "format": "prettier --write . --loglevel warn --ignore-path '.gitignore'",
    "lint": "yarn lint:js && yarn lint:style",
    "lint:js": "eslint . --ext ts --ext tsx --ext js",
    "lint:style": "stylelint '**/*.{css,scss,js,ts,tsx}'",
    "semantic-release": "semantic-release",
    "start": "next start",
    "type-check": "tsc --pretty --noEmit"
  },
  "babel": {
    "extends": "./config/babel.config.json"
  },
  "eslintConfig": {
    "extends": "./config/.eslintrc.json"
  },
  "stylelint": {
    "extends": "./config/.stylelintrc.json"
  },
  "resolutions": {
    "styled-components": "^5"
  },
  "dependencies": {
    "formik": "^2.2.6",
    "next": "^10.0.9",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-icons": "^4.2.0",
    "react-slick": "^0.28.1",
    "styled-components": "^5.2.1",
    "yup": "^0.32.9"
  },
  "devDependencies": {
    "@types/node": "^14.14.35",
    "@types/react": "^17.0.3",
    "@types/react-dom": "^17.0.2",
    "@types/react-slick": "^0.23.4",
    "@types/styled-components": "^5.1.9",
    "@typescript-eslint/eslint-plugin": "^4.18.0",
    "@typescript-eslint/parser": "^4.18.0",
    "babel-plugin-styled-components": "^1.12.0",
    "eslint-plugin-react": "^7.22.0",
    "stylelint-config-styled-components": "^0.1.1",
    "typescript": "^4.2.3"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "release": {
    "extends": "./config/release.config.js"
  }
}
